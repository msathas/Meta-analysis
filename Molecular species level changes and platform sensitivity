#Helpers
# Extract Heat, Cold, and Heat-Cold contrast from any metafor fit
extract_HC <- function(fit) {
  b <- coef(fit)
  V <- vcov(fit)
  
  needed <- c("TreatmentHeat", "TreatmentCold")
  if (!all(needed %in% names(b))) return(NULL)
  
  mu_heat <- unname(b["TreatmentHeat"])
  mu_cold <- unname(b["TreatmentCold"])
  se_heat <- sqrt(unname(V["TreatmentHeat","TreatmentHeat"]))
  se_cold <- sqrt(unname(V["TreatmentCold","TreatmentCold"]))

  L <- rep(0, length(b)); names(L) <- names(b)
  L["TreatmentHeat"] <- 1
  L["TreatmentCold"] <- -1
  
  diff <- sum(L * b)
  se_diff <- sqrt(as.numeric(t(L) %*% V %*% L))
  z <- diff / se_diff
  p <- 2 * pnorm(-abs(z))
  
  tibble(
    mu_heat = mu_heat, se_heat = se_heat,
    mu_cold = mu_cold, se_cold = se_cold,
    diff_heat_minus_cold = diff,
    se_diff = se_diff,
    p_value = p
  )
}

# Build a significance label
p_to_star <- function(p) {
  dplyr::case_when(
    is.na(p) ~ NA_character_,
    p < 0.001 ~ "***",
    p < 0.01  ~ "**",
    p < 0.05  ~ "*",
    TRUE ~ "ns"
  )
}

# Fit one dataset with a given moderator formula and choose rma.mv vs rma.uni FE
# Returns list(fit=..., model_used=...)
fit_meta <- function(d, mods_formula, use_random = TRUE) {
  # must have both treatments
  if (n_distinct(d$Treatment) < 2) return(NULL)
  
  n_study <- n_distinct(d$Study)
  
  # Prefer rma.mv with Study random if estimable and requested
  if (use_random && n_study >= 2) {
    fit <- tryCatch(
      suppressWarnings(
        rma.mv(yi, vi,
               mods = mods_formula,
               random = ~ 1 | Study,
               data = d)
      ),
      error = function(e) NULL
    )
    if (!is.null(fit)) return(list(fit = fit, model_used = "rma.mv_study_random"))
  }
  
  # Fallback: fixed-effect meta-regression
  fit <- tryCatch(
    suppressWarnings(
      rma.uni(yi, vi,
              mods = mods_formula,
              method = "FE",
              data = d)
    ),
    error = function(e) NULL
  )
  if (!is.null(fit)) return(list(fit = fit, model_used = "rma.uni_FE"))
  
  NULL
}

# 3-step fallback fitting:
fit_with_fallbacks <- function(d, pooled = FALSE) {
  # For pooled models we include platform as adjustment when possible
  # but if it makes the model singular, we allow it to drop (as last fallback).
  if (pooled) {
    f1 <- ~ 0 + Treatment + platform + Tissue + plant_species  #  M1: ~ 0 + Treatment + Tissue + plant_species (+ platform in pooled)
    f2 <- ~ 0 + Treatment + platform + Tissue   #  M2: ~ 0 + Treatment + Tissue (+ platform in pooled)
    f3 <- ~ 0 + Treatment + platform       #  M3: ~ 0 + Treatment (+ platform in pooled)
    f4 <- ~ 0 + Treatment
    formulas <- list(M1 = f1, M2 = f2, M3 = f3, M4 = f4)
  } else {
    f1 <- ~ 0 + Treatment + Tissue + plant_species  #  M1: ~ 0 + Treatment + Tissue + plant_species
    f2 <- ~ 0 + Treatment + Tissue                  #  M2: ~ 0 + Treatment + Tissue 
    f3 <- ~ 0 + Treatment                           #  M3: ~ 0 + Treatment 
    formulas <- list(M1 = f1, M2 = f2, M3 = f3)
  }
  
  for (nm in names(formulas)) {
    out <- fit_meta(d, formulas[[nm]], use_random = TRUE)
    if (!is.null(out)) {
      hc <- extract_HC(out$fit)
      if (!is.null(hc)) {
        return(list(
          fit = out$fit,
          model_used = paste0(ifelse(pooled, "pooled_", "split_"), nm, "_", out$model_used),
          hc = hc
        ))
      }
    }
  }
  NULL
}

#split model (per platform)
df_DI <- df %>% filter(platform == "DI-MS/MS") #similarly, choose other platforms one by one

fit_one_key_split <- function(d) {
  out <- fit_with_fallbacks(d, pooled = FALSE)
  if (is.null(out)) return(NULL)
  
  tibble(
    model = "DI-MS/MS_split",
    model_used = out$model_used,
    n_total_studies = n_distinct(d$Study),
    n_heat_studies  = n_distinct(d$Study[d$Treatment=="Heat"]),
    n_cold_studies  = n_distinct(d$Study[d$Treatment=="Cold"])
  ) %>% bind_cols(out$hc)
}

