#SENSITIVITY: pooled-with-platform vs split-by-platform
#A) Pooled per key (platform as fixed effect when possible)
fit_one_key_pooled <- function(d) {
  out <- fit_with_fallbacks(d, pooled = TRUE)
  if (is.null(out)) return(NULL)
  
  # platform overlap (confounding diagnostic): common platforms between Heat and Cold
  common_plat <- length(intersect(unique(d$platform[d$Treatment=="Heat"]),
                                  unique(d$platform[d$Treatment=="Cold"])))
  
  tibble(
    model = "pooled",
    model_used = out$model_used,
    n_total_studies = n_distinct(d$Study),
    n_heat_studies  = n_distinct(d$Study[d$Treatment=="Heat"]),
    n_cold_studies  = n_distinct(d$Study[d$Treatment=="Cold"]),
    n_platforms = n_distinct(d$platform),
    common_platforms = common_plat
  ) %>% bind_cols(out$hc)
}

pooled_results <- df %>%
  group_by(across(all_of(key_cols))) %>%
  group_modify(~{
    res <- fit_one_key_pooled(.x)
    if (is.null(res)) tibble() else res
  }) %>%
  ungroup() %>%
  mutate(
    significance = dplyr::case_when(
      common_platforms == 0 ~ NA_character_,  # platform-confounded: do not star
      TRUE ~ p_to_star(p_value)
    )
  )

write.csv(pooled_results, "POOLED_platform_adjusted_results_lipidclass_mol.csv", row.names = FALSE)

#B) Split by platform per key (same 3-step fallback, no platform term)
fit_one_key_platform_split <- function(d) {
  out <- fit_with_fallbacks(d, pooled = FALSE)
  if (is.null(out)) return(NULL)
  
  tibble(
    model = "platform_split",
    model_used = out$model_used,
    n_total_studies = n_distinct(d$Study),
    n_heat_studies  = n_distinct(d$Study[d$Treatment=="Heat"]),
    n_cold_studies  = n_distinct(d$Study[d$Treatment=="Cold"])
  ) %>% bind_cols(out$hc)
}

split_results <- df %>%
  group_by(platform, across(all_of(key_cols))) %>%
  group_modify(~{
    res <- fit_one_key_platform_split(.x)
    if (is.null(res)) tibble() else res
  }) %>%
  ungroup()

write.csv(split_results, "SPLIT_by_platform_results_lipidclass_mol.csv", row.names = FALSE)

#C) Combine split estimates across platforms (inverse-variance weighting on contrast)
split_combined <- split_results %>%
  filter(is.finite(se_diff), se_diff > 0) %>%
  group_by(across(all_of(key_cols))) %>%
  summarise(
    diff_split = sum(diff_heat_minus_cold / se_diff^2, na.rm = TRUE) / sum(1 / se_diff^2, na.rm = TRUE),
    se_split   = sqrt(1 / sum(1 / se_diff^2, na.rm = TRUE)),
    k_platforms = n_distinct(platform),
    .groups = "drop"
  )

#D) Compare pooled vs split-combined
compare_tbl <- pooled_results %>%
  select(all_of(key_cols),
         diff_pooled = diff_heat_minus_cold,
         se_pooled = se_diff,
         common_platforms, n_platforms) %>%
  inner_join(split_combined, by = key_cols) %>%
  mutate(
    sign_match = sign(diff_pooled) == sign(diff_split),
    abs_diff = abs(diff_pooled - diff_split)
  )

compare_summary <- compare_tbl %>%
  summarise(
    n_keys = n(),
    prop_sign_match = mean(sign_match, na.rm = TRUE),
    cor_diff = cor(diff_pooled, diff_split, use = "complete.obs"),
    median_abs_diff = median(abs_diff, na.rm = TRUE)
  )

compare_by_platform <- split_results %>%
  select(platform, all_of(key_cols),
         diff_platform = diff_heat_minus_cold,
         se_platform = se_diff) %>%
  inner_join(
    pooled_results %>% select(all_of(key_cols),
                              diff_pooled = diff_heat_minus_cold,
                              se_pooled = se_diff),
    by = key_cols
  ) %>%
  mutate(
    sign_match = sign(diff_pooled) == sign(diff_platform),
    abs_diff = abs(diff_pooled - diff_platform)
  ) %>%
  group_by(platform) %>%
  summarise(
    n_keys = n(),
    prop_sign_match = mean(sign_match, na.rm = TRUE),
    cor_diff = cor(diff_pooled, diff_platform, use = "complete.obs"),
    median_abs_diff = median(abs_diff, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  arrange(desc(n_keys))

write.csv(compare_tbl, "COMPARE_pooled_vs_splitcombined.csv", row.names = FALSE)
write.csv(compare_summary, "COMPARE_summary.csv", row.names = FALSE)
write.csv(compare_by_platform, "COMPARE_by_platform.csv", row.names = FALSE)

print(compare_summary)
