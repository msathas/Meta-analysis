########Bayesian modeling at Lipid class level
library(tidyverse)
library(brms)
library(posterior)

#This analysis was done per treatment. Assuming the input data are cold_data and heat_data, respectively.
#Repeat the following steps for heat_data as well.

BASE_DIR <- "Final_meta_outputs"
INFILE   <- file.path(BASE_DIR, "Cold_model_input.csv")

OUTDIR <- file.path(BASE_DIR, "bayes_fit_Cold_pooled_N01_E1")
dir.create(OUTDIR, showWarnings = FALSE, recursive = TRUE)

# ---- settings ----
CHAINS      <- 4
CORES       <- 4
ITER        <- 4000
WARMUP      <- 1000
ADAPT_DELTA <- 0.99
MAX_TREED   <- 15
SEED        <- 1
INIT_VAL    <- 0.1

# ---- data ----
df_raw <- read_csv(INFILE, show_col_types = FALSE)

df <- df_raw %>%
  mutate(
    Study         = factor(Study),
    platform      = factor(platform),
    Treatment     = factor(Treatment),
    Lipid_class   = factor(Lipid_class),
    Tissue        = factor(Tissue),
    Growth_stage  = factor(Growth_stage),
    plant_species = factor(plant_species)
  ) %>%
  filter(is.finite(yi), is.finite(vi), vi > 0) %>%
  droplevels()

write_csv(df, file.path(OUTDIR, "Cold_model_input_factorized.csv"))

# ---- model ----
f_pooled <- bf(
  yi | se(sqrt(vi)) ~ 0 +
    Lipid_class +                #to allow the direct comparison of lipid class differences (on the same scale), lipid class was included in the model.
    Lipid_class:Tissue +         #Allows the lipid-class effect to differ by tissue
    Lipid_class:Growth_stage +   #Allows the lipid-class effect to differ by growth stage
    platform +                   #Adjusts for systematic shifts in effect size due to analytical platforms
    (1 | Study) +                #Accounts for within-study dependence and study-level heterogeneity    
    (0 + Lipid_class || plant_species) +     #Species variaiton of lipid classes. Independent group-level effects (||) were estimated because the model includes a large
                                            #number of lipid-class-specific random slopes with sparse and highly unbalanced species coverage.
    (1 || plant_species:Tissue:Lipid_class)  #3-way interactions
)

priors <- c(
  prior(normal(0, 1), class = "b"),
  prior(exponential(1), class = "sd")
)

fit_pooled_cold <- brm(
  formula = f_pooled,
  data = df,
  family = gaussian(),
  prior = priors,
  chains = CHAINS, iter = ITER, warmup = WARMUP, cores = CORES,
  backend = "cmdstanr",
  init = INIT_VAL,
  control = list(adapt_delta = ADAPT_DELTA, max_treedepth = MAX_TREED),
  seed = SEED,
  refresh = 50,
  file_refit = "never"
)

saveRDS(fit_pooled_cold, file.path(OUTDIR, "fit_pooled_cold.rds"))

# ---- diagnostics ----
dr <- as_draws_array(fit_pooled_cold)
ess_tbl <- tibble(parameter = posterior::variables(dr)) %>%
  rowwise() %>%
  mutate(
    bulk_ess = posterior::ess_bulk(dr[, , parameter, drop = FALSE])[[1]],
    tail_ess = posterior::ess_tail(dr[, , parameter, drop = FALSE])[[1]],
    rhat     = posterior::rhat(dr[, , parameter, drop = FALSE])[[1]]
  ) %>%
  ungroup()

write_csv(ess_tbl, file.path(OUTDIR, "diagnostics_ESS_Rhat_Cold_pooled.csv"))

sink(file.path(OUTDIR, "model_summary_Cold_pooled.txt"))
print(summary(fit_pooled_cold))
sink()

cat("DONE. Cold pooled fit saved to:", normalizePath(OUTDIR), "\n")
