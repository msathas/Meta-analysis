########Bayesian modeling at Lipid class level
library(tidyverse)
library(brms)
library(posterior)

#This analysis was done per treatment. The below code was used for cold stress data.
#The analysis was done in multiple steps such as, data preparation and hormonization (manual), fitting the model, and posterior estimate extraction.
#The data preparation and harmonization involves extracting data from the literature (as described in the Manuscript) and organizing the data.
#For heat stress data, same code was used with appropriate dataset.

BASE_DIR <- "Final_meta_outputs"
INFILE   <- file.path(BASE_DIR, "Cold_model_input.csv")

OUTDIR <- file.path(BASE_DIR, "bayes_fit_Cold_pooled_N01_E1")
dir.create(OUTDIR, showWarnings = FALSE, recursive = TRUE)

# ---- settings ----
CHAINS      <- 4
CORES       <- 4
ITER        <- 4000
WARMUP      <- 1000
ADAPT_DELTA <- 0.99
MAX_TREED   <- 15
SEED        <- 1
INIT_VAL    <- 0.1

# ---- data ----
df_raw <- read_csv(INFILE, show_col_types = FALSE)

df <- df_raw %>%
  mutate(
    Study         = factor(Study),
    platform      = factor(platform),
    Treatment     = factor(Treatment),
    Lipid_class   = factor(Lipid_class),
    Tissue        = factor(Tissue),
    Growth_stage  = factor(Growth_stage),
    plant_species = factor(plant_species)
  ) %>%
  filter(is.finite(yi), is.finite(vi), vi > 0) %>%
  droplevels()

write_csv(df, file.path(OUTDIR, "Cold_model_input_factorized.csv"))

# ---- model ----
f_pooled <- bf(
  yi | se(sqrt(vi)) ~ 0 +
    Lipid_class +                #to allow the direct comparison of lipid class differences (on the same scale), lipid class was included in the model.
    Lipid_class:Tissue +         #Allows the lipid-class effect to differ by tissue
    Lipid_class:Growth_stage +   #Allows the lipid-class effect to differ by growth stage
    platform +                   #Adjusts for systematic shifts in effect size due to analytical platforms
    (1 | Study) +                #Accounts for within-study dependence and study-level heterogeneity    
    (0 + Lipid_class || plant_species) +     #Species variaiton of lipid classes. Independent group-level effects (||) were estimated because the model includes a large
                                            #number of lipid-class-specific random slopes with sparse and highly unbalanced species coverage.
    (1 || plant_species:Tissue:Lipid_class)  #3-way interactions
)

priors <- c(
  prior(normal(0, 1), class = "b"),
  prior(exponential(1), class = "sd")
)

fit_pooled_cold <- brm(
  formula = f_pooled,
  data = df,
  family = gaussian(),
  prior = priors,
  chains = CHAINS, iter = ITER, warmup = WARMUP, cores = CORES,
  backend = "cmdstanr",
  init = INIT_VAL,
  control = list(adapt_delta = ADAPT_DELTA, max_treedepth = MAX_TREED),
  seed = SEED,
  refresh = 50,
  file_refit = "never"
)

saveRDS(fit_pooled_cold, file.path(OUTDIR, "fit_pooled_cold.rds"))

# ---- diagnostics ----
dr <- as_draws_array(fit_pooled_cold)
ess_tbl <- tibble(parameter = posterior::variables(dr)) %>%
  rowwise() %>%
  mutate(
    bulk_ess = posterior::ess_bulk(dr[, , parameter, drop = FALSE])[[1]],
    tail_ess = posterior::ess_tail(dr[, , parameter, drop = FALSE])[[1]],
    rhat     = posterior::rhat(dr[, , parameter, drop = FALSE])[[1]]
  ) %>%
  ungroup()

write_csv(ess_tbl, file.path(OUTDIR, "diagnostics_ESS_Rhat_Cold_pooled.csv"))

sink(file.path(OUTDIR, "model_summary_Cold_pooled.txt"))
print(summary(fit_pooled_cold))
sink()

cat("DONE. Cold pooled fit saved to:", normalizePath(OUTDIR), "\n")


# Posterior estimate extraction

fit <- readRDS(FITFILE)
if (posterior::ndraws(as_draws(fit)) <= 0) stop("Fit has no posterior draws: ", FITFILE)


# Core extractor (platform/stage marginalization is controlled by marginal_vars)
extract_marginal <- function(fit, keep_vars, marginal_vars, re_formula_used = NA) {
  dd <- fit$data
  vi_ref <- stats::median(dd$vi, na.rm = TRUE)

  keep_df <- dd %>% distinct(across(all_of(keep_vars)))
  marg_df <- dd %>% distinct(across(all_of(marginal_vars)))

  grid <- tidyr::crossing(keep_df, marg_df) %>%
    mutate(vi = vi_ref)

  # Align factor levels to fit$data (hard fail if mismatch)
  common <- intersect(names(grid), names(dd))
  for (v in common) {
    if (is.factor(dd[[v]])) {
      grid[[v]] <- factor(as.character(grid[[v]]), levels = levels(dd[[v]]))
    }
  }
  for (v in common) {
    if (is.factor(dd[[v]]) && any(is.na(grid[[v]]))) {
      stop("newdata has levels not in fit$data for: ", v)
    }
  }

  lp <- posterior_linpred(
    fit,
    newdata = grid,
    re_formula = re_formula_used,
    allow_new_levels = FALSE
  ) # draws × n_grid

  grp <- interaction(grid[, keep_vars, drop = FALSE], drop = TRUE, lex.order = TRUE)
  idx_list <- split(seq_len(nrow(grid)), grp)

  lp_marg <- sapply(idx_list, function(idx) rowMeans(lp[, idx, drop = FALSE]))
  if (is.vector(lp_marg)) lp_marg <- matrix(lp_marg, ncol = 1)

  keys <- keep_df %>%
    mutate(.grp = interaction(across(all_of(keep_vars)), drop = TRUE, lex.order = TRUE)) %>%
    distinct(.grp, .keep_all = TRUE) %>%
    arrange(match(.grp, colnames(lp_marg))) %>%
    select(-.grp)

  est      <- apply(lp_marg, 2, mean)
  se_post  <- apply(lp_marg, 2, sd)
  q2.5     <- apply(lp_marg, 2, quantile, probs = 0.025)
  q97.5    <- apply(lp_marg, 2, quantile, probs = 0.975)
  q5       <- apply(lp_marg, 2, quantile, probs = 0.05)
  q95      <- apply(lp_marg, 2, quantile, probs = 0.95)
  prob_pos <- apply(lp_marg, 2, function(x) mean(x > 0))

  bind_cols(
    tibble(stress = STRESS),
    keys,
    tibble(
      est = est,
      se_post = se_post,
      q2.5 = q2.5,
      q97.5 = q97.5,
      q5 = q5,
      q95 = q95,
      prob_pos = prob_pos,
      direction_95 = case_when(
        q2.5 > 0  ~ "increase",
        q97.5 < 0 ~ "decrease",
        TRUE      ~ "no_clear_change"
      ),
      direction_p90 = case_when(
        prob_pos >= 0.90 ~ "increase",
        prob_pos <= 0.10 ~ "decrease",
        TRUE             ~ "no_clear_change"
      )
    )
  )
}

# L1: Lipid_class (platform + plant species + Tissue marginalized)
L1 <- extract_marginal(
  fit,
  keep_vars = c("Lipid_class"),
  marginal_vars = c("plant_species", "Tissue", "Growth_stage", "platform"),
  re_formula_used = NA
)
write_csv(L1, OUT_L1)

# L2: plant_species × Lipid_class (platform + Tissue marginalized)
# include plant_species lipid random slopes
L2 <- extract_marginal(
  fit,
  keep_vars = c("plant_species", "Lipid_class"),
  marginal_vars = c("Tissue", "Growth_stage", "platform"),
  re_formula_used = ~(0 + Lipid_class || plant_species)
)
write_csv(L2, OUT_L2)

# L3: Tissue × Lipid_class (platform + plant species marginalized)
L3 <- extract_marginal(
  fit,
  keep_vars = c("Tissue", "Lipid_class"),
  marginal_vars = c("plant_species", "Growth_stage", "platform"),
  re_formula_used = NA
)
write_csv(L3, OUT_L3)

# L4: plant_species x Tissue x Lipid_class (platform marginalized) 
L4 <- extract_marginal(
  fit,
  keep_vars = c("plant_species", "Tissue", "Lipid_class"),
  marginal_vars = c("Growth_stage", "platform"),
  re_formula_used = ~(1 || plant_species:Tissue:Lipid_class)
)
write_csv(L4, OUT_L4)
