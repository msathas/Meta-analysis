library(tidyverse)
library(brms)
library(posterior)

###This analysis was done per treatment. Assuming the input data is cold_data and heat_data respectively.

# Data preparation
meta_cold <- cold_data %>%
  filter(!is.na(yi), !is.na(vi)) %>%
  mutate(group = interaction(plant_species, Tissue, Lipid_class, drop = TRUE))

# Hierarchical Bayesian model: varying intercept by study and group
fit_bayes <- brm(
  formula = yi | se(sqrt(vi)) ~ 1 + (1 | Study) + (1 | group),
  data = meta_cold,
  prior = c(
    prior(normal(0, 1), class = "Intercept"),
    prior(cauchy(0, 1), class = "sd")  # weakly informative priors
  ),
  chains = 4,
  iter = 4000,
  warmup = 1000,
  control = list(adapt_delta = 0.95),
  cores = 4
)

summary(fit_bayes)

# Extract posterior estimates per group
cposterior_group <- coef(fit_bayes)$group %>%
  as.data.frame() %>%
  rownames_to_column("group") %>%
  separate(group, into = c("plant_species", "Tissue", "Growth_stage", "Lipid_class"), sep = "\\.")
