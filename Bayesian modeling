########Bayesian modeling at Lipid class level
library(tidyverse)
library(brms)
library(posterior)

#This analysis was done per treatment. Assuming the input data are cold_data and heat_data, respectively.
#Repeat the following steps for heat_data as well.

# Data preparation
meta_cold <- cold_data %>%
  filter(!is.na(yi), !is.na(vi)) %>%
  mutate(group = interaction(plant_species, Tissue, Lipid_class, drop = TRUE))

# Hierarchical Bayesian model: varying intercept by study and group
fit_bayes <- brm(
  formula = yi | se(sqrt(vi)) ~ 1 + (1 | Study) + (1 | group),
  data = meta_cold,
  prior = c(
    prior(normal(0, 1), class = "Intercept"),
    prior(cauchy(0, 1), class = "sd")  # weakly informative priors
  ),
  chains = 4,
  iter = 4000,
  warmup = 1000,
  control = list(adapt_delta = 0.95),
  cores = 4
)

summary(fit_bayes)

# Extract posterior estimates per group
cposterior_group <- coef(fit_bayes)$group %>%
  as.data.frame() %>%
  rownames_to_column("group") %>%
  separate(group, into = c("plant_species", "Tissue", "Growth_stage", "Lipid_class"), sep = "\\.")

# Extract posterior draws as a dataframe
draws <- as_draws_df(fit_bayes)

# Summarize draws (includes mean, sd, Bulk_ESS, Tail_ESS, Rhat, etc.)
ess_summary <- summarise_draws(draws)

# Filter to get only group-level effects
group_ess <- ess_summary %>%
  filter(grepl("^r_group", variable))  # r_group includes varying intercepts per group

# View the results
group_ess %>%
  select(variable, mean, sd, ess_bulk, ess_tail, rhat)

group_ess_clean <- group_ess %>%
  # Step 1: Extract what's inside brackets: e.g. "Arabidopsis.thaliana.Leaf.PC"
  mutate(group = str_extract(variable, "(?<=\\[).+?(?=,)")) %>%
  
  # Step 2: Split into up to 4 pieces
  separate(group, into = c("genus", "species", "tissue", "lipid_class"), sep = "\\.", fill = "right", extra = "merge") %>%
  
  # Step 3: Recombine genus and species
  mutate(
    plant_species = paste(genus, species, sep = "."),
    lipid_class = ifelse(is.na(lipid_class), "Total", lipid_class)
  ) %>%
  
  # Step 4: Final clean table
  select(-genus, -species)

