#########Wilcoxon rank sum test (Mann-Whitney U test) for molecular species
#Assuming the input data is combined_data (with lipid_class, molecular species, treatment, effect size and their variance columns)

# Perform Wilcoxon rank sum test (Mann-Whitney U test) for each molecular species under each lipid class
significance_results <- combined_data %>% 
  group_by(Lipid_class, Molecular_species) %>%
  filter(sum(Treatment == "Heat") >= 1, sum(Treatment == "Cold") >= 1) %>%  # Ensure both treatments are present
  summarise(
    p_value = wilcox.test(yi ~ Treatment, exact = FALSE)$p.value,  # Use approximation method if ties exist
    .groups = "drop"
  ) %>%
  mutate(
    significance = case_when(
      p_value < 0.05 ~ "*",  # Significant if p-value < 0.05
      TRUE ~ "ns"  # "ns" for not significant
    )
  )

# Check the significance results
head(significance_results)

######### Check the results
combined_data_with_significance <- combined_data %>%
  left_join(significance_results, by = c("Lipid_class", "Molecular_species"))

# Aggregate data by Molecular_species and Treatment to get one row per combination (if needed)
combined_data_aggregated <- combined_data_with_significance %>%
  filter(Molecular_species != "" & !is.na(Molecular_species)) %>%  # Filter out empty or NA molecular species
  group_by(Molecular_species, Treatment, Lipid_class) %>%
  summarise(
    # Calculate the weighted mean effect size
    mean_yi = sum(yi / vi, na.rm = TRUE) / sum(1 / vi, na.rm = TRUE),  # Weighted mean of yi
    # Calculate the weighted standard error (SE)
    se_yi = sqrt(1 / sum(1 / vi, na.rm = TRUE)),  # Weighted SE from variances
    # Handle missing values in significance, replace with "ns" if all are NA
    significance = ifelse(all(is.na(significance)), "ns", na.omit(significance)[1]),  # Use the first non-missing significance
    .groups = "drop"
  )
