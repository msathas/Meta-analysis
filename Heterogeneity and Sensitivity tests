#################Sensitivity test
#Assuming input data is heat_data
# Optional: Sensitivity
leave1out_mv <- function(data, study_col = "Study") {
  unique_studies <- unique(data[[study_col]])
  results <- lapply(unique_studies, function(study) {
    data_loo <- data %>% filter(.data[[study_col]] != study)
    model <- tryCatch(
      rma.mv(yi, vi, random = ~1 | Study, data = data_loo),
      error = function(e) NULL
    )
    if (!is.null(model)) {
      data.frame(
        Study = study,
        yi = coef(model)[1],
        se = sqrt(vcov(model)[1, 1])
      )
    } else {
      data.frame(Study = study, yi = NA, se = NA)
    }
  })
  do.call(rbind, results)
}

heat_sensitivity <- leave1out_mv(heat_data)

res_adj <- rma.mv(yi, vi, random = ~1 | Study, data = heat_sensitivity)
summary(res_adj)

