#######Modeling and normality check for analysis at the molecular species level 

# Assuming the input is combined_data
# Modeling is done per lipid class per molecular species separately

# Create group_id combining Lipid_class and Molecular_species
combined_data <- combined_data %>%
  mutate(group_id = paste(Lipid_class, Molecular_species, sep = "_"))

# Get unique groups
groups <- unique(combined_data$group_id)

cat("Total groups to fit:", length(groups), "\n")

# Prepare empty list to store results
results_list <- list()

# Loop over groups to fit Bayesian meta-analysis models
for (g in groups) {
  cat("Fitting model for group:", g, "\n")

  dat_sub <- combined_data %>% filter(group_id == g)

  # Skip groups without both treatments (Heat and Cold)
  if(length(unique(dat_sub$Treatment)) < 2) next

  fit <- brm(
    formula = yi | se(sqrt(vi)) ~ Treatment + (1 | Study),
    data = dat_sub,
    prior = c(
      prior(normal(0, 1), class = "Intercept"),
      prior(cauchy(0, 1), class = "sd")
    ),
    chains = 4,
    iter = 2000,
    warmup = 500,
    cores = 4,
    control = list(adapt_delta = 0.95),
    silent = TRUE,
    refresh = 0
  )

  summ <- summary(fit)$fixed
  treat_row <- summ[rownames(summ) == "TreatmentHeat", ]

  results_list[[g]] <- data.frame(
    group = g,
    estimate = treat_row["Estimate"],
    se = treat_row["Est.Error"],
    lower95 = treat_row["l-95% CI"],
    upper95 = treat_row["u-95% CI"],
    significant = ifelse(treat_row["l-95% CI"] > 0 | treat_row["u-95% CI"] < 0, TRUE, FALSE)
  )
}

# Combine all results into one dataframe
results_df <- bind_rows(results_list)

# Save results to CSV
write_csv(results_df, "bayesian_meta_results.csv")
