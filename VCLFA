##############Very long chain fatty acid analysis
#Assuming the input data is combined_data (with treatment, lipid class, molecular species, effect size and variance)

# 1. Extract carbon number and filter for VLCFAs (assuming molecular species is in a format of 36:3)
combined_data$Carbon <- as.numeric(sub(":.*", "", combined_data$Molecular_species))

filtered_data <- combined_data %>%
  filter(Carbon >= 42) %>%
  select(-Carbon)

# 3. Remove rows with missing values in key variables
filtered_data_clean <- filtered_data %>%
  filter(!is.na(yi), !is.na(vi), !is.na(Lipid_class), !is.na(Molecular_species),
         !is.na(plant_species), !is.na(Tissue), !is.na(Treatment))

# 4. Normalize Lipid_class and Molecular_species for matching
filtered_data_clean <- filtered_data_clean %>%
  mutate(
    Lipid_class = str_trim(Lipid_class),
    Molecular_species = str_trim(Molecular_species)
  )

filtered_data_clean %>%
  distinct(Lipid_class, Molecular_species)

############Here, the combinations of lipid class and molecular species that may not have at least one 22C must be removed. This step explicitly need manual curing of data to avoid
#including the lipids that have more than 2 fatty acid chains that was previously included when 42C was used to filter the lipids.

##Assuming you have removed misleading lipids
meta_data <- filtered_data_clean %>%
  anti_join(excluded_combos, by = c("Lipid_class", "Molecular_species")) %>%
  mutate(
    Carbon_n = as.numeric(sub(":.*", "", Molecular_species))
  )

#Run meta-analysis per group
data_heat <- meta_data %>% filter(Treatment == "Heat") %>% droplevels()
data_cold <- meta_data %>% filter(Treatment == "Cold") %>% droplevels()

# FIT MODELS

# Settings
CHAINS <- 4; ITER <- 4000; WARMUP <- 1000; CORES <- 4; SEED <- 123

fit_heat <- brm(
  yi | se(sqrt(vi)) ~ 1 + (1 | Study) + (1 | Species_ID),
  data = data_heat, family = gaussian(),
  prior = c(prior(normal(0, 1), class = "Intercept"), prior(exponential(1), class = "sd")),
  chains = CHAINS, iter = ITER, warmup = WARMUP, cores = CORES, seed = SEED,
  backend = "cmdstanr", file = "fit_heat_vlcfa"
)

fit_cold <- brm(
  yi | se(sqrt(vi)) ~ 1 + (1 | Study) + (1 | Species_ID),
  data = data_cold, family = gaussian(),
  prior = c(prior(normal(0, 1), class = "Intercept"), prior(exponential(1), class = "sd")),
  chains = CHAINS, iter = ITER, warmup = WARMUP, cores = CORES, seed = SEED,
  backend = "cmdstanr", file = "fit_cold_vlcfa"
)

# EXTRACT EFFECTS

extract_effects_fixed <- function(fit, treatment_name) {
  # Get random effects
  re <- ranef(fit)$Species_ID
  
  effects <- as.data.frame(re[, , "Intercept"]) %>%
    rownames_to_column("Species_ID") %>%
    rename(estimate = Estimate, se = Est.Error, ci_lower = Q2.5, ci_upper = Q97.5) %>%
    # Split the combined ID back into Class and Species
    separate(Species_ID, into = c("Lipid_class", "Molecular_species"), 
             sep = ":", remove = FALSE, extra = "merge") %>%
    mutate(
      Treatment = treatment_name,
      p_dir = pmax(1 - pnorm(0, estimate, se), pnorm(0, estimate, se)),
      direction = ifelse(estimate > 0, "increase", "decrease"),
      sig_95 = (ci_lower > 0 & ci_upper > 0) | (ci_lower < 0 & ci_upper < 0)
    )
  return(effects)
}

all_results <- bind_rows(
  extract_effects_fixed(fit_heat, "Heat"),
  extract_effects_fixed(fit_cold, "Cold")
)

